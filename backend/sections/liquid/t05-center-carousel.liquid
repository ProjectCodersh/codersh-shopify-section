{% comment %}
  T05 – Center Carousel | TAE Block
  Schema headers: 6 (TAE max for non-interactive settings)
  CSS variables: all wired via .t05--{{ section.id }}
  JS: prev/next/dot/swipe navigation, scoped IIFE
  Scoped to: .t05--{{ section.id }}
  Last updated: 2026-04-09
{% endcomment %}

{%- liquid
  assign names      = section.settings.names     | split: '|'
  assign roles      = section.settings.roles     | split: '|'
  assign companies  = section.settings.companies | split: '|'
  assign quotes     = section.settings.quotes    | split: '|'
  assign avatars    = section.settings.avatars   | split: '|'
  assign metrics    = section.settings.metrics   | split: '|'
  assign ratings    = section.settings.ratings   | split: '|'
  assign card_count = quotes | size
  assign last_idx   = card_count | minus: 1
-%}

<div
  class="t05 t05--{{ section.id }}"
  id="t05-{{ section.id }}"
  {{ block.shopify_attributes }}
>

  {%- comment -%} ── Section Heading ── {%- endcomment -%}
  <div class="t05__header">
    {%- if section.settings.eyebrow_text != blank -%}
      <p class="t05__eyebrow">{{ section.settings.eyebrow_text }}</p>
    {%- endif -%}
    {%- if section.settings.heading_text != blank -%}
      <h2 class="t05__heading">{{ section.settings.heading_text }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading_text != blank -%}
      <p class="t05__subheading">{{ section.settings.subheading_text }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} ── Carousel ── {%- endcomment -%}
  {%- if card_count > 0 -%}
    <div class="t05__track" role="region" aria-label="Client testimonials carousel">

      {%- for quote in quotes -%}
        {%- liquid
          assign idx = forloop.index0
          if idx == 0
            assign init_pos = 'center'
          elsif idx == 1
            assign init_pos = 'right'
          elsif idx == last_idx
            assign init_pos = 'left'
          else
            assign init_pos = 'hidden'
          endif
          assign rating_val = ratings[idx] | plus: 0
          if rating_val == 0
            assign rating_val = 5
          endif
        -%}
        <article
          class="t05__card"
          data-index="{{ idx }}"
          data-pos="{{ init_pos }}"
          aria-label="Testimonial from {{ names[idx] | default: 'Customer' }}"
        >
          <div class="t05__card-inner">

            {%- comment -%} Stars {%- endcomment -%}
            <div class="t05__stars" role="img" aria-label="{{ rating_val }} out of 5 stars">
              {%- for s in (1..5) -%}
                {%- if s <= rating_val -%}
                  <svg class="t05__star t05__star--on" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                    <path d="M8 1l1.94 3.93 4.33.63-3.13 3.05.74 4.31L8 10.77l-3.88 2.04.74-4.31L1.73 5.56l4.33-.63L8 1z"/>
                  </svg>
                {%- else -%}
                  <svg class="t05__star" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                    <path d="M8 1l1.94 3.93 4.33.63-3.13 3.05.74 4.31L8 10.77l-3.88 2.04.74-4.31L1.73 5.56l4.33-.63L8 1z"/>
                  </svg>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- comment -%} Quote {%- endcomment -%}
            <blockquote class="t05__quote">&#8220;{{ quote }}&#8221;</blockquote>

            {%- comment -%} Metric badge {%- endcomment -%}
            {%- if metrics[idx] != blank -%}
              <div class="t05__badge-wrap">
                <span class="t05__badge">{{ metrics[idx] }}</span>
              </div>
            {%- endif -%}

            {%- comment -%} Author {%- endcomment -%}
            <div class="t05__author">
              <div class="t05__avatar-wrap">
                {%- if avatars[idx] != blank -%}
                  <img
                    src="{{ avatars[idx] }}"
                    alt="{{ names[idx] }}"
                    class="t05__avatar-img"
                    width="36" height="36"
                    loading="lazy"
                  />
                {%- else -%}
                  <div class="t05__avatar-initial" aria-hidden="true">
                    {{ names[idx] | slice: 0 | upcase }}
                  </div>
                {%- endif -%}
              </div>
              <div class="t05__author-meta">
                <p class="t05__name">{{ names[idx] }}</p>
                <p class="t05__role">
                  {{- roles[idx] -}}
                  {%- if companies[idx] != blank -%}&nbsp;&middot;&nbsp;{{ companies[idx] }}{%- endif -%}
                </p>
              </div>
            </div>

          </div>
        </article>
      {%- endfor -%}

    </div>

    {%- comment -%} ── Navigation Controls ── {%- endcomment -%}
    <div class="t05__controls">
      <button class="t05__arrow t05__arrow--prev" type="button" aria-label="Previous testimonial">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      <div class="t05__dots" role="tablist" aria-label="Testimonial navigation">
        {%- for quote in quotes -%}
          <button
            class="t05__dot{%- if forloop.first %} t05__dot--active{%- endif %}"
            data-index="{{ forloop.index0 }}"
            role="tab"
            type="button"
            aria-selected="{%- if forloop.first -%}true{%- else -%}false{%- endif -%}"
            aria-label="Go to testimonial {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>

      <button class="t05__arrow t05__arrow--next" type="button" aria-label="Next testimonial">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>

  {%- else -%}
    <p class="t05__empty">Add testimonial content in the block settings to get started.</p>
  {%- endif -%}

</div>

<style>
  /* ── CSS Custom Properties ─────────────────────────────── */
  .t05--{{ section.id }} {
    --t05-bg:              {{ section.settings.section_bg }};
    --t05-eyebrow-color:   {{ section.settings.eyebrow_color }};
    --t05-heading-color:   {{ section.settings.heading_color }};
    --t05-subheading-color:{{ section.settings.subheading_color }};
    --t05-card-bg-center:  {{ section.settings.card_bg_center }};
    --t05-card-bg-side:    {{ section.settings.card_bg_side }};
    --t05-card-border-c:   {{ section.settings.card_border_center }};
    --t05-card-border-s:   {{ section.settings.card_border_side }};
    --t05-card-radius:     {{ section.settings.card_border_radius }}px;
    --t05-card-w:          {{ section.settings.card_width }}px;
    --t05-offset:          {{ section.settings.side_card_offset }}px;
    --t05-track-h:         {{ section.settings.carousel_height }}px;
    --t05-star-color:      {{ section.settings.star_color }};
    --t05-quote-color:     {{ section.settings.quote_color }};
    --t05-name-color:      {{ section.settings.name_color }};
    --t05-role-color:      {{ section.settings.role_color }};
    --t05-badge-bg:        {{ section.settings.badge_bg }};
    --t05-badge-color:     {{ section.settings.badge_color }};
    --t05-badge-border:    {{ section.settings.badge_border }};
    --t05-arrow-bg:        {{ section.settings.arrow_bg }};
    --t05-arrow-border:    {{ section.settings.arrow_border }};
    --t05-arrow-icon:      {{ section.settings.arrow_icon_color }};
    --t05-dot-active:      {{ section.settings.dot_active_color }};
    --t05-dot-inactive:    {{ section.settings.dot_inactive_color }};
    {%- if section.settings.use_custom_font -%}
    --t05-heading-font: {{ section.settings.heading_font_family.family }}, {{ section.settings.heading_font_family.fallback_families }};
    --t05-body-font:    {{ section.settings.body_font_family.family }}, {{ section.settings.body_font_family.fallback_families }};
    {%- endif -%}

    background:     var(--t05-bg);
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left:   1.5rem;
    padding-right:  1.5rem;
    overflow:       hidden;
    box-sizing:     border-box;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .t05--{{ section.id }} .t05__header {
    text-align:    {{ section.settings.heading_alignment | downcase }};
    margin-bottom: 4rem;
  }
  .t05--{{ section.id }} .t05__eyebrow {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--t05-eyebrow-color); margin: 0 0 1rem;
    {%- if section.settings.use_custom_font -%}font-family: var(--t05-body-font);{%- endif -%}
  }
  .t05--{{ section.id }} .t05__heading {
    font-size: {{ section.settings.heading_size }}; font-weight: 800;
    letter-spacing: -0.02em; line-height: 1.1;
    color: var(--t05-heading-color); margin: 0 0 1rem;
    {%- if section.settings.use_custom_font -%}font-family: var(--t05-heading-font);{%- endif -%}
  }
  .t05--{{ section.id }} .t05__subheading {
    font-size: 1rem; line-height: 1.6; color: var(--t05-subheading-color);
    margin: 0; max-width: 36rem;
    {%- if section.settings.heading_alignment == 'Center' -%}margin-left: auto; margin-right: auto;{%- endif -%}
    {%- if section.settings.use_custom_font -%}font-family: var(--t05-body-font);{%- endif -%}
  }

  /* ── Carousel Track ──────────────────────────────────────── */
  .t05--{{ section.id }} .t05__track {
    position: relative; height: var(--t05-track-h);
    max-width: {{ section.settings.section_max_width }};
    margin: 0 auto 2.5rem;
  }

  /* ── Cards ───────────────────────────────────────────────── */
  .t05--{{ section.id }} .t05__card {
    position: absolute; top: 0; left: 50%;
    width: var(--t05-card-w);
    transform: translateX(-50%) scale(0.7);
    opacity: 0; z-index: 1; pointer-events: none;
    border-radius: var(--t05-card-radius); overflow: hidden;
    border: 1px solid var(--t05-card-border-s);
    background: var(--t05-card-bg-side); box-sizing: border-box;
    {%- if section.settings.enable_animations -%}
    transition: transform 0.5s ease, opacity 0.5s ease;
    {%- endif -%}
  }
  .t05--{{ section.id }} .t05__card[data-pos="center"] {
    transform: translateX(-50%) scale(1); opacity: 1; z-index: 3;
    pointer-events: auto; background: var(--t05-card-bg-center);
    border-color: var(--t05-card-border-c);
  }
  .t05--{{ section.id }} .t05__card[data-pos="right"] {
    transform: translateX(calc(-50% + var(--t05-offset))) scale(0.82);
    opacity: 0.45; z-index: 2; pointer-events: auto; cursor: pointer;
  }
  .t05--{{ section.id }} .t05__card[data-pos="left"] {
    transform: translateX(calc(-50% - var(--t05-offset))) scale(0.82);
    opacity: 0.45; z-index: 2; pointer-events: auto; cursor: pointer;
  }

  /* ── Card Inner ─────────────────────────────────────────── */
  .t05--{{ section.id }} .t05__card-inner {
    padding: 1.75rem; display: flex; flex-direction: column;
    gap: 1.125rem; height: 100%; box-sizing: border-box;
  }

  /* ── Stars ──────────────────────────────────────────────── */
  .t05--{{ section.id }} .t05__stars { display: flex; gap: 0.25rem; }
  .t05--{{ section.id }} .t05__star { width: 1rem; height: 1rem; flex-shrink: 0; fill: rgba(255,255,255,0.12); }
  .t05--{{ section.id }} .t05__star--on { fill: var(--t05-star-color); }

  /* ── Quote ──────────────────────────────────────────────── */
  .t05--{{ section.id }} .t05__quote {
    font-size: 0.9375rem; font-weight: 300; line-height: 1.75;
    margin: 0; font-style: normal; flex: 1; color: var(--t05-quote-color);
    {%- if section.settings.use_custom_font -%}font-family: var(--t05-body-font);{%- endif -%}
  }

  /* ── Badge ──────────────────────────────────────────────── */
  .t05--{{ section.id }} .t05__badge-wrap { display: flex; }
  .t05--{{ section.id }} .t05__badge {
    display: inline-block; font-size: 0.75rem; font-weight: 600;
    color: var(--t05-badge-color); background: var(--t05-badge-bg);
    border: 1px solid var(--t05-badge-border);
    padding: 0.375rem 0.875rem; border-radius: 9999px;
  }

  /* ── Author ─────────────────────────────────────────────── */
  .t05--{{ section.id }} .t05__author {
    display: flex; align-items: center; gap: 0.75rem;
    padding-top: 1.125rem; border-top: 1px solid rgba(255,255,255,0.1); margin-top: auto;
  }
  .t05--{{ section.id }} .t05__avatar-wrap { flex-shrink: 0; }
  .t05--{{ section.id }} .t05__avatar-img {
    width: 36px; height: 36px; border-radius: 50%; object-fit: cover; display: block;
    outline: 1px solid rgba(255,255,255,0.2);
  }
  .t05--{{ section.id }} .t05__avatar-initial {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--t05-eyebrow-color); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.875rem; font-weight: 700;
  }
  .t05--{{ section.id }} .t05__name {
    color: var(--t05-name-color); font-weight: 600; font-size: 0.875rem; margin: 0 0 0.2rem;
    {%- if section.settings.use_custom_font -%}font-family: var(--t05-body-font);{%- endif -%}
  }
  .t05--{{ section.id }} .t05__role {
    color: var(--t05-role-color); font-size: 0.75rem; margin: 0;
    {%- if section.settings.use_custom_font -%}font-family: var(--t05-body-font);{%- endif -%}
  }

  /* ── Controls ───────────────────────────────────────────── */
  .t05--{{ section.id }} .t05__controls {
    display: flex; align-items: center; justify-content: center; gap: 1.25rem;
  }
  .t05--{{ section.id }} .t05__arrow {
    width: 2.5rem; height: 2.5rem; border-radius: 50%;
    border: 1px solid var(--t05-arrow-border); background: var(--t05-arrow-bg);
    color: var(--t05-arrow-icon); display: flex; align-items: center;
    justify-content: center; cursor: pointer; flex-shrink: 0; padding: 0;
    {%- if section.settings.enable_animations -%}transition: background 0.2s ease, border-color 0.2s ease;{%- endif -%}
  }
  .t05--{{ section.id }} .t05__arrow:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.3); }
  .t05--{{ section.id }} .t05__arrow svg { width: 1rem; height: 1rem; }
  .t05--{{ section.id }} .t05__dots { display: flex; gap: 0.5rem; align-items: center; }
  .t05--{{ section.id }} .t05__dot {
    width: 8px; height: 8px; border-radius: 9999px;
    border: none; background: var(--t05-dot-inactive); cursor: pointer; padding: 0;
    {%- if section.settings.enable_animations -%}transition: width 0.3s ease, background 0.3s ease;{%- endif -%}
  }
  .t05--{{ section.id }} .t05__dot--active { width: 24px; background: var(--t05-dot-active); }

  /* ── Empty state ── */
  .t05--{{ section.id }} .t05__empty { text-align: center; color: var(--t05-subheading-color); font-size: 0.875rem; padding: 2rem; }

  /* ── Tablet ≤768px ───────────────────────────────────────── */
  @media (max-width: 768px) {
    .t05--{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
    .t05--{{ section.id }} .t05__heading { font-size: {{ section.settings.mobile_heading_size }}px; }
    .t05--{{ section.id }} .t05__header { margin-bottom: 2.5rem; }
    .t05--{{ section.id }} .t05__track { height: auto; overflow: visible; }
    .t05--{{ section.id }} .t05__card {
      position: relative; left: auto; transform: none; opacity: 0;
      width: 100%; max-width: 360px; margin: 0 auto; display: none; transition: none;
    }
    .t05--{{ section.id }} .t05__card[data-pos="center"] { display: block; opacity: 1; transform: none; }
    .t05--{{ section.id }} .t05__card[data-pos="left"],
    .t05--{{ section.id }} .t05__card[data-pos="right"] { display: none; }
  }
  @media (max-width: 480px) {
    .t05--{{ section.id }} .t05__card-inner { padding: 1.25rem; }
  }
</style>

<script>
(function () {
  var root    = document.getElementById('t05-{{ section.id }}');
  if (!root) return;
  var cards   = Array.from(root.querySelectorAll('.t05__card'));
  var dots    = Array.from(root.querySelectorAll('.t05__dot'));
  var btnPrev = root.querySelector('.t05__arrow--prev');
  var btnNext = root.querySelector('.t05__arrow--next');
  var count   = cards.length;
  var active  = 0;
  if (count === 0) return;

  function posFor(i, a) {
    var d = (i - a + count) % count;
    if (d === 0)         return 'center';
    if (d === 1)         return 'right';
    if (d === count - 1) return 'left';
    return 'hidden';
  }
  function go(n) {
    active = ((n % count) + count) % count;
    cards.forEach(function (c, i) { c.dataset.pos = posFor(i, active); });
    dots.forEach(function (d, i) {
      var on = i === active;
      d.classList.toggle('t05__dot--active', on);
      d.setAttribute('aria-selected', on ? 'true' : 'false');
    });
  }
  cards.forEach(function (c, i) {
    c.addEventListener('click', function () { if (c.dataset.pos !== 'center') go(i); });
  });
  if (btnPrev) btnPrev.addEventListener('click', function () { go(active - 1); });
  if (btnNext) btnNext.addEventListener('click', function () { go(active + 1); });
  dots.forEach(function (d, i) { d.addEventListener('click', function () { go(i); }); });
  var sx = 0;
  root.addEventListener('touchstart', function (e) { sx = e.changedTouches[0].clientX; }, { passive: true });
  root.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - sx;
    if (Math.abs(dx) > 48) go(dx < 0 ? active + 1 : active - 1);
  }, { passive: true });
  go(0);
})();
</script>

{% schema %}
{
  "name": "T05 \u2013 Center Carousel",
    "settings": [
    { "type": "header", "content": "Testimonial Content" },
    {
      "type": "textarea", "id": "names",
      "label": "Names (pipe-separated)",
      "default": "Shreyans Bajaj|James Walker|Emily Carter|Michael Reed|Brandon Lee"
    },
    {
      "type": "textarea", "id": "roles",
      "label": "Roles (pipe-separated)",
      "default": "Founder|Owner|Marketing Director|Founder|Owner"
    },
    {
      "type": "textarea", "id": "companies",
      "label": "Companies (pipe-separated)",
      "default": "Custom Photo Books|Texas Baseball Co.|Hudson Pecan|D2C Supplement Brand|Lone Star Apparel"
    },
    {
      "type": "textarea", "id": "quotes",
      "label": "Quotes (pipe-separated)",
      "default": "Codersh built our entire customization flow from scratch. Conversion improved significantly within weeks of launch.|The new Shopify site feels premium and our sales jumped 38%. Best dev investment we've made.|The site loads faster and looks significantly more polished. Bounce rate dropped immediately after launch.|From Figma to Shopify, execution was flawless. They understand design and conversion at the same level.|Zero downtime migration. Clean code, instant speed improvement, and our team can actually maintain it now."
    },
    {
      "type": "textarea", "id": "avatars",
      "label": "Avatar URLs (pipe-separated, blank = initials fallback)",
      "default": "https://i.pravatar.cc/80?img=11|https://i.pravatar.cc/80?img=52|https://i.pravatar.cc/80?img=44|https://i.pravatar.cc/80?img=15|https://i.pravatar.cc/80?img=32"
    },
    {
      "type": "textarea", "id": "metrics",
      "label": "Metric badges (pipe-separated)",
      "default": "Conversions up|+38% sales|Score 51 \u2192 94|Figma \u2192 Live in 5wk|Zero downtime"
    },
    {
      "type": "text", "id": "ratings",
      "label": "Star ratings (pipe-separated, 1\u20135)",
      "default": "5|5|5|5|5"
    },

    { "type": "header", "content": "Section Heading" },
    {
      "type": "text", "id": "eyebrow_text",
      "label": "Eyebrow label", "default": "Client Reviews"
    },
    {
      "type": "color", "id": "eyebrow_color",
      "label": "Eyebrow color", "default": "#8DB832"
    },
    {
      "type": "textarea", "id": "heading_text",
      "label": "Heading", "default": "What our clients say"
    },
    {
      "type": "color", "id": "heading_color",
      "label": "Heading color", "default": "#ffffff"
    },
    {
      "type": "select", "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "2rem", "label": "Small (32px)" },
        { "value": "3rem", "label": "Medium (48px)" },
        { "value": "4rem", "label": "Large (64px)" }
      ],
      "default": "3rem"
    },
    {
      "type": "textarea", "id": "subheading_text",
      "label": "Subheading", "default": "Trusted by high-growth Shopify brands."
    },
    {
      "type": "color", "id": "subheading_color",
      "label": "Subheading color", "default": "#94a3b8"
    },
    {
      "type": "select", "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "Left",   "label": "Left" },
        { "value": "Center", "label": "Center" },
        { "value": "Right",  "label": "Right" }
      ],
      "default": "Center"
    },

    { "type": "header", "content": "Colors" },
    {
      "type": "color", "id": "section_bg",
      "label": "Section background", "default": "#080d1a"
    },
    {
      "type": "color", "id": "card_bg_center",
      "label": "Center card background", "default": "#3a3a3a"
    },
    {
      "type": "color", "id": "card_bg_side",
      "label": "Side card background", "default": "#2c2c2c"
    },
    {
      "type": "color", "id": "card_border_center",
      "label": "Center card border", "default": "#555555"
    },
    {
      "type": "color", "id": "card_border_side",
      "label": "Side card border", "default": "#333333"
    },
    {
      "type": "color", "id": "quote_color",
      "label": "Quote text color", "default": "#ffffff"
    },
    {
      "type": "color", "id": "star_color",
      "label": "Star color", "default": "#f59e0b"
    },
    {
      "type": "color", "id": "name_color",
      "label": "Author name color", "default": "#ffffff"
    },
    {
      "type": "color", "id": "role_color",
      "label": "Author role color", "default": "#94a3b8"
    },
