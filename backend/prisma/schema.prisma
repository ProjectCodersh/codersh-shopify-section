generator client {
  provider = "prisma-client-js"
}

// ── Local development database (SQLite) ──────────────────────────────────────
// Switch to postgresql + Supabase URL when deploying to production.
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ── Active models ─────────────────────────────────────────────────────────────

model InstalledSection {
  id          String   @id @default(cuid())
  shop        String
  sectionId   String
  sectionName String
  installedAt DateTime @default(now())

  @@unique([shop, sectionId])
}

