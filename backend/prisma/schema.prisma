generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model InstalledSection {
  id          String   @id @default(cuid())
  shop        String
  sectionId   String
  sectionName String
  installedAt DateTime @default(now())

  @@unique([shop, sectionId])
}