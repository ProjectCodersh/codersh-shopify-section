# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Force LF for these file types regardless of OS
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.toml text eol=lf
*.liquid text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.env  text eol=lf

# Binary files — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.db   binary
